# ==============================================================================
# SEFIN Audit Tool - Configuração de Ambiente
# ==============================================================================
# Este é o setup OFICIAL do projeto.
# As variáveis na seção "Obrigatório" são geradas automaticamente pelo `start.js`.
# As demais seções são avançadas ou opcionais.

# ------------------------------------------------------------------------------
# 1. OBRIGATÓRIO (Gerado pelo start.js no primeiro fluxo de inicialização)
# ------------------------------------------------------------------------------
DATABASE_URL=file:./sefin_audit.db
PYTHON_API_PORT=8001
PORT=3000
OAUTH_SERVER_URL=http://localhost:3000/mock-oauth
VITE_OAUTH_PORTAL_URL=http://localhost:3000/mock-oauth
VITE_APP_ID=sefin-audit-tool
VITE_ANALYTICS_ENDPOINT=mock-endpoint
VITE_ANALYTICS_WEBSITE_ID=mock-id

# Autenticação e Criptografia
JWT_SECRET=local_dev_secret_12345678

# ------------------------------------------------------------------------------
# 2. OPCIONAL / AVANÇADO (Sobrescrevem os defaults se definidos)
# ------------------------------------------------------------------------------
# Ambiente
# NODE_ENV=development

# Credenciais Oracle Salvas (Para manter sessão no backend Python)
# SAVED_ORACLE_USER=seu_cpf_ou_usuario

# Configuração de Logs
# LOG_LEVEL=INFO
