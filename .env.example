# ==============================================================================
# SEFIN Audit Tool - Configuração de Ambiente
# ==============================================================================
# Este é o setup OFICIAL do projeto.
# As variáveis na seção "Obrigatório" são geradas automaticamente pelo `start.js`.
# As demais seções são avançadas, legadas ou para casos de uso específicos.

# ------------------------------------------------------------------------------
# 1. OBRIGATÓRIO (Gerado pelo start.js no primeiro fluxo de inicialização)
# ------------------------------------------------------------------------------
DATABASE_URL=file:./sefin_audit.db
PYTHON_API_PORT=8001
PORT=3000
OAUTH_SERVER_URL=http://localhost:3000/mock-oauth
VITE_OAUTH_PORTAL_URL=http://localhost:3000/mock-oauth
VITE_APP_ID=sefin-audit-tool
VITE_ANALYTICS_ENDPOINT=mock-endpoint
VITE_ANALYTICS_WEBSITE_ID=mock-id

# Autenticação e Criptografia
JWT_SECRET=local_dev_secret_12345678

# ------------------------------------------------------------------------------
# 2. OPCIONAL / AVANÇADO (Sobrescrevem os defaults se definidos)
# ------------------------------------------------------------------------------
# Ambiente
# NODE_ENV=development

# Credenciais Oracle Salvas (Para manter sessão no backend Python)
# SAVED_ORACLE_USER=seu_cpf_ou_usuario

# Configuração de Logs
# LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# 3. LEGADO (Não são mais usadas no fluxo principal Web, apenas em scripts locais antigos)
# ------------------------------------------------------------------------------
# Conexões diretas Oracle (Substituído por conexão dinâmica na interface web)
# ORACLE_HOST=exa01-scan.sefin.ro.gov.br
# ORACLE_PORT=1521
# ORACLE_SERVICE=sefindw
# DB_USER=your_db_user_here
# DB_PASSWORD=your_db_password_here

# ORACLE_HOST_1=exacc-x10-sefinscan.sefin.ro.gov.br
# ORACLE_PORT_1=1521
# ORACLE_SERVICE_1=svc.bi.users
# DB_USER_1=your_db_user_here
# DB_PASSWORD_1=your_db_password_here

# PostgreSQL (local) - Antigo banco de metadados antes da migração para SQLite via Drizzle
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=your_pg_password_here

# Configurações do PySide6 / Dashboard Legado
# CACHE_ENABLED=true
# CACHE_TTL=3600
# DASHBOARD_THEME=dark
# DASHBOARD_WIDTH=wide

# Visão Contribuinte (Scripts autônomos)
# Login_Visao_360=your_visao_login_here
# Senha_Visao_350=your_visao_senha_here
